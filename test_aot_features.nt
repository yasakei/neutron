// Comprehensive AOT v2+ feature test

// Test 1: Global Variables
say("=== Test 1: Global Variables ===");
var globalCounter = 0;
var globalMessage = "Global test passed";

fun incrementGlobal() {
    globalCounter = globalCounter + 1;
}

incrementGlobal();
incrementGlobal();
incrementGlobal();
say(globalMessage + " (counter=" + globalCounter + ")");

// Test 2: Constant Folding / Optimization
say("\n=== Test 2: Optimization ===");
var x = 0;
x = x + 1;
x = x + 1;
x = x + 1;
say("Optimization test: x=" + x + " (expected: 3)");

// Test 3: Arrays (basic support)
say("\n=== Test 3: Arrays ===");
var arr = [1, 2, 3];
say("Array created with " + 3 + " elements");

// Test 4: Increment/Decrement operators
say("\n=== Test 4: Increment/Decrement ===");
var counter = 10;
counter = counter + 1;  // Will use INCREMENT_LOCAL optimization
say("After increment: " + counter);
counter = counter - 1;  // Will use DECREMENT_LOCAL
say("After decrement: " + counter);

// Test 5: Debug mode info (visible in generated C++)
say("\n=== Test 5: All features working ===");
say("AOT v2+ features test completed successfully!");

// Test 6: Global increment
say("\n=== Test 6: Global Increment ===");
globalCounter = globalCounter + 1;
say("Global counter after increment: " + globalCounter);

say("\n=== All Tests Passed ===");
