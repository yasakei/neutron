// Linked List benchmark in Neutron

// Simple linked list using arrays with O(1) tail append
var list_data = [];
var list_next = [];
var list_head = -1;
var list_tail = -1;

fun listAppend(data) {
    var idx = list_data.length;
    list_data.push(data);
    list_next.push(-1);
    
    if (list_head == -1) {
        list_head = idx;
        list_tail = idx;
    } else {
        list_next[list_tail] = idx;
        list_tail = idx;
    }
    return idx;
}

fun listFind(data) {
    var current = list_head;
    while (current != -1) {
        if (list_data[current] == data) {
            return current;
        }
        current = list_next[current];
    }
    return -1;
}

fun listDelete(data) {
    if (list_head == -1) {
        return;
    }
    if (list_data[list_head] == data) {
        list_head = list_next[list_head];
        return;
    }
    var current = list_head;
    while (list_next[current] != -1) {
        var nextIdx = list_next[current];
        if (list_data[nextIdx] == data) {
            list_next[current] = list_next[nextIdx];
            return;
        }
        current = nextIdx;
    }
}

fun listLength() {
    var count = 0;
    var current = list_head;
    while (current != -1) {
        count = count + 1;
        current = list_next[current];
    }
    return count;
}

// Create and manipulate linked list
var i = 0;
while (i < 1000) {
    listAppend(i);
    i = i + 1;
}

// Find elements
var count = 0;
var j = 0;
while (j < 1000) {
    if (listFind(j) >= 0) {
        count = count + 1;
    }
    j = j + 10;
}

// Delete some elements
var k = 0;
while (k < 500) {
    listDelete(k);
    k = k + 10;
}

var len = listLength();
say("List length: ${len}, Found: ${count}");

