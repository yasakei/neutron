// Mandelbrot Set benchmark in Neutron

fun mandelbrot(cx, cy, maxIter) {
    var zx = 0;
    var zy = 0;
    var n = 0;
    var tmp;

    while (zx * zx + zy * zy <= 4 and n < maxIter) {
        tmp = zx * zx - zy * zy + cx;
        zy = 2 * zx * zy + cy;
        zx = tmp;
        n = n + 1;
    }
    return n;
}

fun linspace(start, stop, num) {
    var result = [];
    var step = 0;
    if (num > 1) {
        step = (stop - start) / (num - 1);
    }
    var i = 0;
    while (i < num) {
        result.push(start + step * i);
        i = i + 1;
    }
    return result;
}

fun mandelbrotSet(xmin, xmax, ymin, ymax, width, height, maxIter) {
    var r1 = linspace(xmin, xmax, width);
    var r2 = linspace(ymin, ymax, height);
    var count = 0;
    
    var i = 0;
    while (i < width) {
        var x = r1[i];
        var j = 0;
        while (j < height) {
            var c = mandelbrot(x, r2[j], maxIter);
            if (c == maxIter) {
                count = count + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return count;
}

// Calculate mandelbrot set
var width = 200;
var height = 200;
var xmin = -2.0;
var xmax = 1.0;
var ymin = -1.5;
var ymax = 1.5;
var maxIter = 100;

var count = mandelbrotSet(xmin, xmax, ymin, ymax, width, height, maxIter);
say("Mandelbrot points: ${count}");
