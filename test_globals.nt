// Test global variables with AOT compilation

var counter = 0;
var message = "Hello from global!";

fun increment() {
    counter = counter + 1;
    return counter;
}

fun getCounter() {
    return counter;
}

fun setCounter(value) {
    counter = value;
}

// Test basic global access
say(message);
say("Initial counter: " + counter);

// Test increment
increment();
increment();
say("After 2 increments: " + counter);

// Test set
setCounter(100);
say("After setting to 100: " + counter);

// Test get
var current = getCounter();
say("Current counter: " + current);

say("Global variable test passed!");
