// Test: for...in loop over objects and arrays
say("=== for...in Loop ===");

// Test 1: Iterate object keys
var obj = {"a": 1, "b": 2, "c": 3};
var count = 0;
for (var key in obj) {
    count = count + 1;
}
if (count == 3) {
    say("✓ for...in over object iterates all keys");
} else {
    say("FAIL: expected 3 keys, got " + count);
}

// Test 2: Iterate array indices
var arr = [10, 20, 30, 40];
var idx_sum = 0;
for (var i in arr) {
    idx_sum = idx_sum + i;
}
if (idx_sum == 6) {  // 0+1+2+3
    say("✓ for...in over array yields indices");
} else {
    say("FAIL: expected index sum 6, got " + idx_sum);
}

// Test 3: Access values using key inside loop
var scores = {"alice": 95, "bob": 87, "carol": 92};
var total = 0;
for (var name in scores) {
    total = total + scores[name];
}
if (total == 274) {
    say("✓ for...in with value access works");
} else {
    say("FAIL: expected 274, got " + total);
}

// Test 4: Empty object
var empty = {};
var empty_count = 0;
for (var k in empty) {
    empty_count = empty_count + 1;
}
if (empty_count == 0) {
    say("✓ for...in over empty object works");
}

// Test 5: Nested for...in
var matrix = {"row1": [1, 2], "row2": [3, 4]};
var key_count = 0;
for (var row in matrix) {
    key_count = key_count + 1;
}
if (key_count == 2) {
    say("✓ Nested for...in works");
}

say("\n=== All for...in tests passed ===");
