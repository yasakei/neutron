// Test comments
say("=== Testing Comments ===");

// This is a single line comment
var x = 10; // Comment after statement

// Multiple comment lines
// can be written
// like this

if (x == 10) { // Inline comment
    say("✓ Comments don't affect code execution");
}

// Comments can contain special characters: !@#$%^&*()
// Comments can contain quotes: " ' ` 
// Comments with numbers: 123456789

var y = 20; // var z = 30; This is commented out

if (y == 20) {
    say("✓ Commented code is ignored");
}

// Block comments
#{ This is a block comment }#

var a = 5;
#{ 
    This is a
    multi-line block comment
    var a = 999; // this should be ignored
}#

if (a == 5) {
    say("✓ Block comments don't affect code execution");
}

#{ Nested #{ block }# comments work too }#
say("✓ Nested block comments work");

var b = 1; #{ inline block comment }# var c = 2;
if (b == 1 and c == 2) {
    say("✓ Inline block comments work");
}

say("\n=== All comment tests passed ===");
