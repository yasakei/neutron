// AOT Test 2: Pure Computation
// Tests AOT compilation with pure numeric computation

var f5 = 120;  // 5!
var i = 5;
while (i > 1) {
    i = i - 1;
    f5 = f5 / i;
}

var f7 = 5040;  // 7!
i = 7;
while (i > 1) {
    i = i - 1;
    f7 = f7 / i;
}

if (f5 == 1 && f7 == 1) {
    say("AOT computation test PASSED");
} else {
    say("AOT computation test FAILED");
}
