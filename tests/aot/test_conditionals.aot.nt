// AOT Test 6: Conditional Branches
// Tests AOT handling of conditionals

fun testConditionals() {
    var result = 0;
    for (var i = 0; i < 10; i = i + 1) {
        if (i < 5) {
            result = result + 1;
        } else if (i < 8) {
            result = result + 2;
        } else {
            result = result + 3;
        }
    }
    return result;
}

// i=0,1,2,3,4: +1 each = 5
// i=5,6,7: +2 each = 6
// i=8,9: +3 each = 6
// Total = 17
var result = testConditionals();
var expected = 17;

if (result == expected) {
    say("AOT conditionals test PASSED (result=" + result + ")");
} else {
    say("AOT conditionals test FAILED (expected=" + expected + ", got=" + result + ")");
}
