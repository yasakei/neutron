// JIT test - hot loop that should trigger JIT compilation

fun fibonacci(n) {
    if (n <= 1) return n;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fun hotLoop() {
    var sum = 0;
    for (var i = 0; i < 1000; i = i + 1) {
        sum = sum + i;
    }
    return sum;
}

say("Testing JIT compilation...");
say("Fibonacci(10) = " + fibonacci(10));
say("Hot loop sum = " + hotLoop());
say("JIT test completed!");
